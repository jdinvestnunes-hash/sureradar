# Copie este arquivo para ".env" e preencha.

# The Odds API (fonte secundária) — https://the-odds-api.com/
ODDS_API_KEY=coloque_sua_chave_aqui

# surebet.com / apostasseguras — token da API (teste ou pago)
SUREBET_API_TOKEN=coloque_seu_token_aqui

# Telegram (alertas de surebets)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Login com Google (Google Cloud Console → Credentials → OAuth Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Só em DEV: libera a ativação-teste do Pro (NÃO usar em produção)
# ALLOW_DEV_PRO=1
